#!/usr/bin/env node
/**
 * AgentGuard CLI entry point  (Phase 1)
 *
 * Usage:
 *   agentguard <agent> [agent-args...]
 *
 * Examples:
 *   agentguard codex
 *   agentguard claude --print "refactor my auth module"
 *   agentguard aider --model gpt-4
 *
 * Phase 1 behaviour:
 *   • Loads config from agentguard.config.json (local) or ~/.agentguard/config.json
 *   • Auto-detects real TTY → uses PTY interceptor (node-pty)
 *   • Falls back to log-based interceptor when node-pty is unavailable or no TTY
 *   • Prints a session summary box on exit
 */

import chalk from "chalk";
import { readFileSync } from "fs";
import { fileURLToPath } from "url";
import { dirname, join } from "path";
import { createSnapshot } from "../src/snapshot.js";
import { runInterceptor } from "../src/interceptor.js";
import { logSessionStart, LOG_FILE, sessionId } from "../src/logger.js";
import { loadConfig } from "../src/config.js";
import { printSessionSummary } from "../src/summary.js";
import { startFileWatcher } from "../src/filewatcher.js";
import { showPostActionReview } from "../src/reviewer.js";
import { startListener, cleanupPendingAlerts } from "../src/telegram-listener.js";
import { isDaemonRunning } from "../src/daemon-control.js";

// Read the version from package.json at startup so the banner never drifts from
// the published version.  Resolved relative to this file (bin/ → repo root).
let VERSION = "";
try {
  const pkgPath = join(dirname(fileURLToPath(import.meta.url)), "..", "package.json");
  VERSION = JSON.parse(readFileSync(pkgPath, "utf8")).version || "";
} catch {
  // Non-fatal: fall back to an empty version string in the banner.
}

// ─── parse args ───────────────────────────────────────────────────────────────

// Extract agentguard-specific flags before splitting into agent / agentArgs.
const rawArgs = process.argv.slice(2);
const auditOnlyFlag = rawArgs.includes("--audit-only");
const filteredArgs = rawArgs.filter((a) => a !== "--audit-only");
const [agent, ...agentArgs] = filteredArgs;

if (!agent || agent === "--help" || agent === "-h") {
  console.log(`
${chalk.bold.cyan("Ilum")} ${chalk.gray("v" + VERSION)} ${chalk.gray("(formerly AgentGuard)")} — watches what your AI agents do

${chalk.bold("Usage:")}
  agentguard [--audit-only] <agent> [agent-args...]

${chalk.bold("Examples:")}
  agentguard codex
  agentguard claude --print "refactor my auth module"
  agentguard aider --model gpt-4
  agentguard --audit-only claude --print "clean up this project"

${chalk.bold("Setup:")}
  agentguard init              Interactive first-run setup wizard
  agentguard add-path <path>   Add a directory to watchPaths (restarts the daemon if running)

${chalk.bold("Daemon (background file watcher):")}
  agentguard daemon start      Start the daemon detached
  agentguard daemon stop       Send SIGTERM to the running daemon
  agentguard daemon status     Show PID, uptime, watched paths
  agentguard daemon logs       Tail ~/.agentguard/daemon.log
  agentguard daemon install    macOS: register with launchd (auto-start on login)
  agentguard daemon uninstall  macOS: unregister from launchd
  agentguard daemon report     Summarise audit log (alias: agentguard report)
                               Accepts --days=N (default 1 = today)

${chalk.bold("Menu bar app (macOS):")}
  agentguard tray              Launch the menu bar tray app (shows daemon status)
  agentguard tray install      Register with launchd (auto-start on login)
  agentguard tray uninstall    Unregister from launchd

${chalk.bold("What it does:")}
  • Creates a git snapshot of your working tree before the session starts
  • Wraps the agent process and monitors its output for dangerous commands
  • Prompts you to approve or deny risky operations before they execute
  • Writes a full audit log to ${LOG_FILE}

${chalk.bold("Config (optional):")}
  Create agentguard.config.json in the project directory (or
  ~/.agentguard/config.json globally) to customise behaviour.
  Schema: autoApprove, autoDeny, rules.disabled, rules.custom,
          snapshot.enabled, snapshot.restoreOnDeny, auditLog.path
`);
  process.exit(0);
}

// ─── init sub-command ────────────────────────────────────────────────────────

if (agent === "init") {
  const { runInit } = await import("../src/init.js");
  await runInit();
  process.exit(0);
}

// ─── add-path sub-command ──────────────────────────────────────────────────────

if (agent === "add-path") {
  const target = agentArgs[0];
  if (!target) {
    console.error("Usage: agentguard add-path <path>");
    process.exit(1);
  }

  const { addWatchPath } = await import("../src/config.js");
  const os = await import("os");
  const path = await import("path");
  const configPath = path.join(os.homedir(), ".agentguard", "config.json");

  const result = addWatchPath(configPath, target);

  if (result.status === "invalid") {
    console.error(chalk.red(`✗ Not a directory (or does not exist): ${result.path}`));
    process.exit(1);
  }
  if (result.status === "exists") {
    console.log(chalk.yellow(`! ${result.path} already in watchPaths — nothing changed`));
    process.exit(0);
  }

  // status === "added"
  console.log(chalk.green(`✓ Added ${result.path} to watchPaths`));

  // Restart the daemon so it picks up the new path immediately (if running).
  const { isDaemonRunning, daemonStop, daemonStart } = await import("../src/daemon-control.js");
  if (isDaemonRunning()) {
    const n = result.watchPaths.length;
    // When the daemon is launchd-managed (KeepAlive=true), stopping it makes
    // launchd respawn it automatically with the updated config. Calling
    // daemonStart() in that case would race the respawn and abort on "already
    // running", so we only start it ourselves for a manually-run daemon.
    const fs2 = await import("fs");
    const plist = path.join(os.homedir(), "Library", "LaunchAgents", "com.agentguard.daemon.plist");
    const launchdManaged = fs2.existsSync(plist);

    await daemonStop();
    if (launchdManaged) {
      console.log(chalk.green(`✓ Daemon will be respawned by launchd — now watching ${n} path${n === 1 ? "" : "s"}`));
    } else {
      await daemonStart();
      console.log(chalk.green(`✓ Daemon restarted — now watching ${n} path${n === 1 ? "" : "s"}`));
    }
  } else {
    console.log(chalk.gray("  Daemon not running — run `agentguard daemon start` to begin watching."));
  }
  process.exit(0);
}

// ─── dashboard sub-command ────────────────────────────────────────────────────

if (agent === "dashboard") {
  const { startDashboard } = await import("../src/dashboard/server.js");
  await startDashboard();
  process.exit(0);
}

// ─── report sub-command (top-level alias) ────────────────────────────────────

if (agent === "report") {
  const { runReport, parseDaysFlag } = await import("../src/report.js");
  runReport({ days: parseDaysFlag(agentArgs) });
  process.exit(0);
}

// ─── tray sub-command ────────────────────────────────────────────────────────

if (agent === "tray") {
  const sub = agentArgs[0];

  // `agentguard tray install|uninstall` — launchd lifecycle (auto-start on login).
  if (sub === "install" || sub === "uninstall") {
    const mod = await import("../src/tray-control.js");
    await (sub === "install" ? mod.trayInstall() : mod.trayUninstall());
    process.exit(0);
  }

  if (sub) {
    console.error("Usage: agentguard tray [install|uninstall]");
    process.exit(1);
  }

  // No subcommand → launch the menu-bar app in the foreground session.
  const { spawn } = await import("child_process");
  const path = await import("path");
  const fs = await import("fs");
  const { fileURLToPath } = await import("url");

  const trayDir = path.resolve(
    path.dirname(fileURLToPath(import.meta.url)),
    "..",
    "tray"
  );
  const electronBin = path.join(trayDir, "node_modules", ".bin", "electron");

  if (!fs.existsSync(electronBin)) {
    console.error(
      chalk.red("[AgentGuard] tray dependencies not installed.")
    );
    console.error(chalk.gray(`  Run: cd ${trayDir} && npm install`));
    process.exit(1);
  }

  const child = spawn(electronBin, [trayDir], {
    detached: true,
    stdio: "ignore",
  });
  child.unref();
  console.error(
    chalk.green(`[AgentGuard] tray launched (PID ${child.pid})`)
  );
  process.exit(0);
}

// ─── daemon sub-command ──────────────────────────────────────────────────────

if (agent === "daemon") {
  const sub = agentArgs[0];
  const subArgs = agentArgs.slice(1);

  if (sub === "report") {
    const { runReport, parseDaysFlag } = await import("../src/report.js");
    runReport({ days: parseDaysFlag(subArgs) });
    process.exit(0);
  }

  const mod = await import("../src/daemon-control.js");
  const handlers = {
    start:     mod.daemonStart,
    stop:      mod.daemonStop,
    status:    mod.daemonStatus,
    logs:      mod.daemonLogs,
    install:   mod.daemonInstall,
    uninstall: mod.daemonUninstall,
  };
  if (!sub || !handlers[sub]) {
    console.error("Usage: agentguard daemon <start|stop|status|logs|install|uninstall|report>");
    process.exit(1);
  }
  await handlers[sub]();
  process.exit(0);
}

// ─── load config ─────────────────────────────────────────────────────────────

const config = loadConfig();

// --audit-only flag overrides config file setting.
if (auditOnlyFlag) config.auditOnly = true;

// ─── banner ───────────────────────────────────────────────────────────────────

console.error(
  chalk.cyan.bold("\n[AgentGuard]") +
    chalk.white(` Wrapping agent: ${chalk.yellow(agent)}`) +
    (agentArgs.length ? chalk.gray(` ${agentArgs.join(" ")}`) : "")
);
if (config.auditOnly) {
  console.error(chalk.yellow.bold("  [AgentGuard] AUDIT-ONLY MODE — incidents logged, no enforcement"));
}
console.error(chalk.gray(`  Audit log: ${LOG_FILE}`));

// ─── session start ────────────────────────────────────────────────────────────

logSessionStart(agent);
const startTime = Date.now();

// Shared stats object — mutated by whichever interceptor runs.
const stats = {
  commandsSeen: 0,
  intercepted: 0,
  approved: 0,
  blocked: {},
};

// ─── snapshot ─────────────────────────────────────────────────────────────────

let snap = { created: false, message: "Snapshots disabled by config" };

if (config.snapshot.enabled !== false) {
  snap = createSnapshot();
  if (snap.created) {
    console.error(chalk.green(`[AgentGuard] Snapshot: ${snap.message}`));
  } else {
    console.error(chalk.gray(`[AgentGuard] ${snap.message}`));
  }
}

console.error(""); // blank line before agent output begins

// ─── telegram listener ───────────────────────────────────────────────────────

// Long-polls Telegram for callback_query updates from the inline Keep /
// Rollback buttons on file-change alerts.  No-op when Telegram is not
// configured (returns a stub stop()).
//
// Skip when the daemon is already running — Telegram only allows one
// getUpdates poller per bot token (otherwise it returns 409 Conflict).
// The daemon owns the listener in that case.
let listener;
if (isDaemonRunning()) {
  console.error(
    chalk.gray("[AgentGuard] Daemon running — Telegram listener handled by daemon")
  );
  listener = { stop() {} };
} else {
  listener = startListener({
    config,
    sessionId,
    cwd: process.cwd(),
    agent,
  });
}

// ─── choose interceptor ───────────────────────────────────────────────────────

// Use the PTY interceptor when:
//   1. stdout is a real TTY (i.e. not piped/redirected)
//   2. node-pty native bindings are available
// Fall back to log-based interceptor otherwise (CI, pipes, no native build).

let runSession;

if (process.stdout.isTTY) {
  try {
    const { runPtyInterceptor, PTY_AVAILABLE } = await import(
      "../src/pty-interceptor.js"
    );

    if (PTY_AVAILABLE) {
      console.error(chalk.cyan("[AgentGuard] Mode: PTY interceptor\n"));
      runSession = () =>
        runPtyInterceptor({
          agent,
          agentArgs,
          stashRef: snap.stashRef,
          config,
          stats,
        });
    } else {
      console.error(
        chalk.yellow(
          "[AgentGuard] node-pty not available — falling back to log-based mode\n"
        )
      );
    }
  } catch {
    // Import itself failed
    console.error(
      chalk.yellow("[AgentGuard] PTY interceptor failed to load — using log-based mode\n")
    );
  }
}

if (!runSession) {
  console.error(chalk.gray("[AgentGuard] Mode: log-based interceptor\n"));
  runSession = () =>
    runInterceptor({
      agent,
      agentArgs,
      stashRef: snap.stashRef,
      config,
      stats,
    });
}

// ─── file watcher ────────────────────────────────────────────────────────────

const watcher = startFileWatcher({
  cwd: process.cwd(),
  agent,
  sessionId,
  stashRef: snap.stashRef,
  sensitiveBackupDir: snap.sensitiveBackupDir,
  config,
  stats,
});

// ─── run ─────────────────────────────────────────────────────────────────────

try {
  const exitCode = await runSession();

  watcher.stop();
  listener.stop();
  await cleanupPendingAlerts(config);

  // Add file change count to summary
  if (watcher.fileChanges.length > 0) {
    stats.fileChanges = watcher.fileChanges.length;
  }

  // Post-Action Review — runs before the summary box, returns stats if there
  // were sensitive files to review (null if skipped).
  const reviewStats = await showPostActionReview({
    fileChanges: watcher.fileChanges,
    stashRef: snap.stashRef,
    sensitiveBackupDir: snap.sensitiveBackupDir,
    cwd: process.cwd(),
  });

  printSessionSummary({ agent, startTime, stats, snapshot: snap, reviewStats, auditOnly: config.auditOnly });

  process.exit(exitCode);
} catch (err) {
  watcher.stop();
  listener.stop();
  await cleanupPendingAlerts(config);
  console.error(chalk.red(`[AgentGuard] Fatal error: ${err.message}`));
  printSessionSummary({ agent, startTime, stats, snapshot: snap, auditOnly: config.auditOnly });
  process.exit(1);
}
